{
  "name": "@eo/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Core contracts, state machines, canonical errors, and shared schemas (empty stub — phase 02).",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas/*.json": "./schemas/*.json"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:schemas": "tsc -b && node scripts/build-schemas.ts"
  },
  "dependencies": {
    "zod": "3.25.76",
    "zod-to-json-schema": "3.25.2"
  },
  "devDependencies": {
    "fast-check": "4.9.0"
  }
}
