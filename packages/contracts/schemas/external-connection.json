{
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "deploymentType": {
      "type": "string",
      "minLength": 1
    },
    "baseUrl": {
      "type": "string",
      "format": "uri"
    },
    "allowedRedirectOrigins": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "tenantAllowlist": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "orgAllowlist": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "projectAllowlist": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "folderAllowlist": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "customCaRef": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "path"
      ],
      "additionalProperties": false
    },
    "allowedResources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowedActions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "discoveryTtlSeconds": {
      "type": "integer",
      "exclusiveMinimum": 0
    },
    "secretRef": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "backend": {
              "type": "string",
              "const": "env"
            },
            "variable": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "backend",
            "variable"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "backend": {
              "type": "string",
              "const": "file"
            },
            "path": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "backend",
            "path"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "backend": {
              "type": "string",
              "const": "exec"
            },
            "command": {
              "type": "string",
              "minLength": 1
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "required": [
            "backend",
            "command"
          ],
          "additionalProperties": false
        }
      ]
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "provider",
    "baseUrl",
    "allowedRedirectOrigins",
    "allowedResources",
    "allowedActions",
    "discoveryTtlSeconds",
    "secretRef"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}
