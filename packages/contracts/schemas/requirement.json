{
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "intentContractId": {
      "type": "string",
      "format": "uuid"
    },
    "section": {
      "type": "string",
      "enum": [
        "scope",
        "non-goals",
        "audience",
        "compatibility",
        "security",
        "performance",
        "observability",
        "rollout",
        "acceptance"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "workUnitIds": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "renderedArtifactIds": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "testIdentifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidenceRecordIds": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "intentContractId",
    "section",
    "title",
    "description",
    "acceptanceCriteria",
    "workUnitIds",
    "renderedArtifactIds",
    "testIdentifiers",
    "evidenceRecordIds",
    "createdAt"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}
