{
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "ecosystems": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ecosystem": {
            "type": "string",
            "minLength": 1
          },
          "packagePath": {
            "type": "string",
            "minLength": 1
          },
          "buildCommand": {
            "type": "string",
            "minLength": 1
          },
          "testCommands": {
            "type": "object",
            "properties": {
              "unit": {
                "type": "string",
                "minLength": 1
              },
              "integration": {
                "type": "string",
                "minLength": 1
              },
              "e2e": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "unit"
            ],
            "additionalProperties": false
          },
          "benchmarkCommand": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "ecosystem",
          "packagePath",
          "testCommands"
        ],
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "createdAt",
    "ecosystems"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}
