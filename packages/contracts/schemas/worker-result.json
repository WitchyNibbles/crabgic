{
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "workUnitId": {
      "type": "string",
      "format": "uuid"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "cancelled"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "usage": {
      "type": "object",
      "properties": {
        "turnsUsed": {
          "type": "integer",
          "minimum": 0
        },
        "totalCostUsd": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "turnsUsed"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "workUnitId",
    "outcome",
    "summary",
    "diagnostics",
    "usage"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}
