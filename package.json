{
  "name": "engineering-orchestrator-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Engineering Orchestrator monorepo root (private workspaces root; the published CLI package is packages/cli, name \"engineering-orchestrator\").",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:clean": "tsc -b --clean",
    "typecheck": "tsc -b",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:live": "vitest run --config vitest.live.config.ts",
    "lint": "eslint . --ignore-pattern 'spikes/**'",
    "lint:fix": "eslint . --fix --ignore-pattern 'spikes/**'",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "check:workspace-count": "node scripts/check-workspace-count.mjs",
    "check:hygiene": "node scripts/check-repo-hygiene.mjs",
    "check:release-notes": "node scripts/check-release-notes.mjs",
    "check:engine-pin": "node scripts/check-engine-pin.mjs",
    "check:all": "npm run check:workspace-count && npm run check:hygiene && npm run check:release-notes && npm run check:engine-pin"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
